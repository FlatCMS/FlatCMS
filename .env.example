APP_NAME="FlatCMS"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8888
CACHE_ENABLED=true
CACHE_TTL=3600
SESSION_LIFETIME=120
LOG_LEVEL=debug

# Mail (used for password reset + email 2FA)
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# Cloudflare Turnstile (CAPTCHA)
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email 2FA (OTP)
AUTH_2FA_EMAIL_ENABLED=false
AUTH_2FA_EMAIL_ROLES=super_admin,admin
AUTH_2FA_EMAIL_TTL=300
AUTH_2FA_EMAIL_RESEND_COOLDOWN=60
AUTH_2FA_EMAIL_MAX_ATTEMPTS=5
AUTH_2FA_EMAIL_DISABLE_REMEMBER=true
AUTH_2FA_SLOW_LOG_THRESHOLD_MS=2000

# Private license vault
FLATCMS_LICENSE_VAULT_KEY=
FLATCMS_ROUTING_PROBE_KEY=
FLATCMS_SECRETS_KEY=
EXTENSIONS_LOCAL_LICENSE_BYPASS=false

# CSP v2 optional allowlist extensions (space or comma separated)
FLATCMS_CSP_SCRIPT_EXTRA=
FLATCMS_CSP_STYLE_EXTRA=
FLATCMS_CSP_IMG_EXTRA=
FLATCMS_CSP_FONT_EXTRA=
FLATCMS_CSP_CONNECT_EXTRA=
FLATCMS_CSP_FRAME_EXTRA=
FLATCMS_CSP_MEDIA_EXTRA=
FLATCMS_CSP_MANIFEST_EXTRA=
FLATCMS_CSP_WORKER_EXTRA=

# License reveal by email (OTP)
LICENSE_REVEAL_EMAIL_TTL=600
LICENSE_REVEAL_EMAIL_RESEND_COOLDOWN=60
LICENSE_REVEAL_EMAIL_MAX_ATTEMPTS=5

MAIL_SMTP_TIMEOUT=6
MAIL_SLOW_LOG_THRESHOLD_MS=2000

TURNSTILE_SLOW_LOG_THRESHOLD_MS=1500
